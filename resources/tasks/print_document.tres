[gd_resource type="Resource" script_class="TaskData" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/tasks/task_data.gd" id="1_td"]
[ext_resource type="Script" path="res://scripts/tasks/task_step.gd" id="2_ts"]

[sub_resource type="Resource" id="step1"]
script = ExtResource("2_ts")
label = "Open Document"
key_action = "o"
description = "Double-click 'quarterly_report.doc'"
is_timed_wait = false
wait_time = 0.0

[sub_resource type="Resource" id="step2"]
script = ExtResource("2_ts")
label = "File Menu"
key_action = "f"
description = "Click 'File' in the menu bar"
is_timed_wait = false
wait_time = 0.0

[sub_resource type="Resource" id="step3"]
script = ExtResource("2_ts")
label = "Print..."
key_action = "p"
description = "Select 'Print...' from the dropdown"
is_timed_wait = false
wait_time = 0.0

[sub_resource type="Resource" id="step4"]
script = ExtResource("2_ts")
label = "Select Printer"
key_action = "s"
description = "Choose 'HP DeskJet 840C' from the list"
is_timed_wait = false
wait_time = 0.0

[sub_resource type="Resource" id="step5"]
script = ExtResource("2_ts")
label = "Confirm Print"
key_action = "enter"
description = "Click OK to start printing"
is_timed_wait = false
wait_time = 0.0

[sub_resource type="Resource" id="step6"]
script = ExtResource("2_ts")
label = "Spooling..."
key_action = ""
description = "Sending document to print spooler..."
is_timed_wait = true
wait_time = 1.5

[sub_resource type="Resource" id="step7"]
script = ExtResource("2_ts")
label = "Printing..."
key_action = ""
description = "Printing page 1 of 3..."
is_timed_wait = true
wait_time = 2.0

[sub_resource type="Resource" id="step8"]
script = ExtResource("2_ts")
label = "Collect Pages"
key_action = "g"
description = "Grab pages from the printer tray"
is_timed_wait = false
wait_time = 0.0

[resource]
script = ExtResource("1_td")
task_name = "Print Document"
task_id = &"print_document"
description = "The quarterly report needs printing — 3 copies, ASAP!"
steps = [SubResource("step1"), SubResource("step2"), SubResource("step3"), SubResource("step4"), SubResource("step5"), SubResource("step6"), SubResource("step7"), SubResource("step8")]
time_limit = 45.0
base_score = 100
mistake_penalty = 20
max_mistakes = 3
difficulty = 1
task_color = Color(0.55, 0.45, 0.3, 1)
reputation_reward = 0.08
reputation_penalty = 0.12
